# Protección de seguridad - VStoreApp

# Habilitar HTTPS
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# Prevenir clickjacking
Header always set X-Frame-Options "DENY"

# Prevenir MIME sniffing
Header always set X-Content-Type-Options "nosniff"

# Protección XSS
Header always set X-XSS-Protection "1; mode=block"

# Content Security Policy
Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://cdnjs.cloudflare.com; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

# Referrer Policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions Policy
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

# Disable directory listing
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Proteger archivos sensibles
<FilesMatch "\.(env|json|config|sql|log|bak|backup|tmp)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Comprensión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache control
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Prevenir acceso a archivos de configuración
<FilesMatch "^(\.htaccess|\.gitignore|\.env|package\.json|composer\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>
